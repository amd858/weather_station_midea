// Function to handle the raw memory reading and sending
void sendProntoFromProgmem(const uint16_t button_code[]) {
  uint16_t pronto_commands = pgm_read_word(&button_code[2]);
  uint16_t buffer_length = pronto_commands * 2 + 4;

  for (int k = 0; k < buffer_length; k++) {
    pronto_buffer[k] = pgm_read_word(&button_code[k]);
  }

  IrSender.sendPronto(pronto_buffer, buffer_length, 0);
  delay(100);  // Small safety delay between consecutive IR bursts
}

void setup() {
  Serial.begin(115200);

  IrSender.begin();

  // IrSender.begin(); // Default pin is D3 on Uno/Nano, D4 on ESP32
  Serial.println("Dual IR Sender Active...");
}

void loop() {
  // 1. Send Code A
  Serial.println("Sending Code A...");
  sendProntoFromProgmem(cool_28_on_auto_a);

  // 2. Send Code B (Wait slightly after A if they are part of one command)
  delay(500);
  Serial.println("Sending Code B...");
  sendProntoFromProgmem(cool_28_on_auto_b);

  // 3. Wait 10 seconds before repeating the whole cycle
  Serial.println("Waiting 10 seconds...");
  delay(10000);
}